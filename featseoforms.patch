+function resolveSeo(project, page) {
+    const site = project.settings?.seo || {};
+    const pseo = page.seo || {};
+    const baseTitle = (pseo.title && pseo.title.trim()) || page.name;
+    const title = site.siteName ? `${baseTitle} | ${site.siteName}` : baseTitle;
