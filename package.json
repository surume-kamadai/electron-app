{
  "name": "site-builder",
  "version": "1.0.10",
  "description": "GUIでデザインしてHTML/Laravel Bladeを生成するサイトビルダー",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "vendor": "node scripts/copy-vendor.mjs",
    "postinstall": "node scripts/copy-vendor.mjs",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "author": "surume-kamadai",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.surumekamadai.sitebuilder",
    "productName": "Site Builder",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "!src/**/*.test.js",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "@simonwep/pickr": "^1.9.1",
    "golden-layout": "^1.5.9",
    "jquery": "^3.7.1",
    "konva": "^9.3.22"
  }
}
